# Redis connection string. In the Quadlet pod deployment use redis://localhost:6379
# (containers share a network namespace). In Compose, use the service name: redis://redis:6379.
REDIS_URL=redis://localhost:6379

# Public URL of the application (scheme + host + optional subpath), e.g. https://pearls.example.com.
# Used for two purposes:
#   1. SvelteKit adapter-node CSRF protection — the server rejects requests whose
#      Origin header does not match this value.
#   2. Constructing invite links and session cookie paths sent to players.
# If the app is served at a subpath, include it: https://example.com/pearls
ORIGIN=https://pearls.example.com

# ── Push notifications (optional) ────────────────────────────────────────────
# If all three VAPID variables are set, the server sends native push notifications
# to players when it is their turn or the game ends (only when they are not actively
# in the game tab).
# If any variable is absent, push notifications are silently disabled.
#
# Generate a key pair once and store the values as secrets:
#
#   node -e "const wp = require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys(), null, 2))"
#
# PublicKey  → VAPID_PUBLIC_KEY
# PrivateKey → VAPID_PRIVATE_KEY
#
# VAPID_SUBJECT must be either a mailto: address or the canonical HTTPS URL of
# the application. It identifies the server to push services.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@pearls.example.com

# How many seconds of SSE inactivity before a player is considered "away" and
# eligible to receive push notifications. Defaults to 300 (5 minutes).
# Set lower (e.g. 30) during development to test push without long waits.
PUSH_INACTIVITY_SECONDS=300

# ── Cleanup job (optional) ────────────────────────────────────────────────────
# Secret token for the POST /api/admin/cleanup endpoint.
# If not set, the endpoint responds with 503 and cleanup is disabled.
#
# Generate a random secret:
#   openssl rand -hex 32
#
CLEANUP_SECRET=
# Days without activity before a game is deleted. Defaults to 7.
CLEANUP_STALE_GAME_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
# Path to the server log file. Accepts an absolute path or a path relative to
# the process working directory. The directory is created automatically if it
# does not exist. Defaults to logs/app.log.
#
# In production the file receives newline-delimited JSON (one object per event).
# In development (NODE_ENV != production) each event is also printed to stdout
# in a human-readable coloured format via pino-pretty.
#
# Tip: to tail the log in production:
#   tail -f /var/log/pearls/app.log | npx pino-pretty
#
LOG_FILE=logs/app.log
